---
import { nl } from '../i18n/translations';
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Herkenning from '../components/Herkenning.astro';
import Diensten from '../components/Diensten.astro';
import Aanpak from '../components/Aanpak.astro';
import Over from '../components/Over.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---
<Base path="/" lang="nl">
  <Nav t={nl.nav} />
  <main id="main">
    <Hero t={nl.hero} />
    <Herkenning t={nl.herkenning} />
    <Diensten t={nl.diensten} />
    <Aanpak t={nl.aanpak} />
    <Over t={nl.over} />
    <Contact t={nl.contact} />
  </main>
  <Footer t={nl.footer} nav={nl.nav} />
</Base>
