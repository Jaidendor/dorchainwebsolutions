---
import { nl } from '../i18n/translations';
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Base title="Pagina niet gevonden — Dorchain Studio" path="/404" lang="nl">
  <Nav t={nl.nav} />
  <main id="main" class="nf">
    <div class="container nf__inner">
      <p class="eyebrow">Fout 404</p>
      <h1>Deze pagina bestaat niet. Of nog niet.</h1>
      <p>De link klopt niet meer of er is iets verkeerd getypt. Geen zorgen, terug naar veilig terrein:</p>
      <div class="nf__cta">
        <a class="btn" href="/">Naar de homepage</a>
        <a class="btn btn--ghost" href="/#contact">Stel je vraag</a>
      </div>
    </div>
  </main>
  <Footer t={nl.footer} nav={nl.nav} />
</Base>

<style>
  .nf { display: grid; place-items: center; min-height: 60vh; text-align: center; padding-block: var(--space-section); }
  .nf__inner { max-width: 38ch; }
  .nf h1 { font-size: var(--text-h2); margin: 1rem 0 1.2rem; }
  .nf p { color: var(--ink-soft); }
  .nf__cta { display: flex; gap: 0.8rem; justify-content: center; flex-wrap: wrap; margin-top: 1.8rem; }
</style>
