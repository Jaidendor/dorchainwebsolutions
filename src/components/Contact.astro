---
import { site } from '../data/site';
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations['contact'];
}
const { t } = Astro.props;
const mailto = `mailto:${site.email}?subject=${encodeURIComponent(t.subject)}`;
---
<section class="section contact" id="contact">
  <div class="container contact__grid">
    <div class="contact__intro reveal">
      <p class="eyebrow">{t.eyebrow}</p>
      <h2>{t.heading}</h2>
      <p>{t.body}</p>
      <p class="contact__alt">
        {t.altLabel} <a href={mailto}>{site.email}</a>
      </p>
    </div>

    <form class="contact__form reveal" style="--delay:100ms" action={site.formspreeEndpoint} method="POST">
      <input type="hidden" name="_subject" value={t.formSubject} />
      <p class="hp" aria-hidden="true">
        <label>Laat dit veld leeg<input type="text" name="_gotcha" tabindex="-1" autocomplete="off" /></label>
      </p>

      <div class="field">
        <label for="naam">{t.labelName}</label>
        <input id="naam" name="naam" type="text" required autocomplete="name" />
      </div>
      <div class="field">
        <label for="email">{t.labelEmail}</label>
        <input id="email" name="email" type="email" required autocomplete="email" />
      </div>
      <div class="field">
        <label for="website">{t.labelWebsite} <span class="opt">({t.optional})</span></label>
        <input id="website" name="website" type="url" placeholder="https://" autocomplete="url" />
      </div>
      <div class="field">
        <label for="bericht">{t.labelMessage}</label>
        <textarea id="bericht" name="bericht" rows="4" required></textarea>
      </div>

      <button class="btn" type="submit">{t.submit} <span class="arrow" aria-hidden="true">&rarr;</span></button>
      <p class="contact__privacy">
        {t.privacyText} <a href={t.privacyHref}>{t.privacyLink}</a>.
      </p>
    </form>
  </div>
</section>

<style>
  .contact__grid { display: grid; grid-template-columns: 0.85fr 1fr; gap: clamp(2rem, 1rem + 5vw, 4.5rem); align-items: start; }
  .contact__intro h2 { font-size: var(--text-h2); margin: 1rem 0 1.2rem; }
  .contact__intro p { color: var(--ink-soft); max-width: 40ch; }
  .contact__alt { margin-top: 1.5rem; font-size: 0.98rem; }
  .contact__alt a { color: var(--accent-deep); font-weight: 600; }
  .contact__form { background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: clamp(1.5rem, 1rem + 2vw, 2.4rem); box-shadow: 0 30px 60px -40px oklch(23% 0.014 150 / 0.25); }
  .field { margin-bottom: 1.1rem; }
  .field label { display: block; font-size: 0.9rem; font-weight: 600; margin-bottom: 0.45rem; }
  .opt { color: var(--muted); font-weight: 420; }
  .field input, .field textarea { width: 100%; font: inherit; font-size: 1rem; color: var(--ink); padding: 0.8em 0.95em; background: var(--paper-2); border: 1px solid var(--line); border-radius: 12px; transition: border-color 0.2s, background 0.2s; }
  .field input:focus, .field textarea:focus { background: var(--paper); border-color: var(--accent-strong); }
  .field textarea { resize: vertical; min-height: 6.5rem; }
  .contact__form .btn { width: 100%; justify-content: center; margin-top: 0.4rem; }
  .contact__privacy { margin-top: 1rem; font-size: 0.82rem; color: var(--muted); text-align: center; }
  .contact__privacy a { color: var(--ink-soft); }
  .hp { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }
  @media (max-width: 820px) { .contact__grid { grid-template-columns: 1fr; } }
</style>
