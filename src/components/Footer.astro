---
import { site } from '../data/site';
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations['footer'];
  nav: Translations['nav'];
}
const { t, nav } = Astro.props;
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container footer__grid">
    <div class="footer__brand">
      <span class="footer__name">Dorchain<span class="dim"> Web Solutions</span></span>
      <p>{t.tagline}</p>
      <a class="btn btn--ghost btn--on-dark" href={nav.ctaHref}>{t.scan}</a>
    </div>

    <nav class="footer__col" aria-label={nav.lang === 'en' ? 'Footer navigation' : 'Footernavigatie'}>
      <h2>{t.navHeading}</h2>
      <ul>
        {nav.items.map((item) => (<li><a href={item.href}>{item.label}</a></li>))}
      </ul>
    </nav>

    <div class="footer__col">
      <h2>{t.contactHeading}</h2>
      <ul>
        <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
        <li class="dim">{site.city}</li>
        <li><a href={t.privacyHref}>{t.privacyLink}</a></li>
      </ul>
    </div>

    <div class="footer__col">
      <h2>{t.businessHeading}</h2>
      <ul>
        <li class="dim">{t.soleprop}</li>
        <li class="dim">{t.kvkLabel} {site.kvk}</li>
        <li class="dim">{t.vatLabel} {site.btw}</li>
      </ul>
    </div>
  </div>

  <div class="container footer__base">
    <span>&copy; {year} {site.person}</span>
    <span class="footer__pledge">{t.pledge}</span>
  </div>
</footer>

<style>
  .footer { background: var(--dark); color: var(--on-dark); padding-top: clamp(3rem, 2rem + 4vw, 5rem); position: relative; z-index: 2; }
  .footer__grid { display: grid; grid-template-columns: 1.6fr 1fr 1fr 1fr; gap: 2.5rem 1.5rem; padding-bottom: 3rem; border-bottom: 1px solid var(--dark-line); }
  .footer__name { font-family: var(--font-display); font-size: 1.4rem; font-weight: 600; color: var(--paper); }
  .footer__name .dim { color: var(--on-dark-soft); font-weight: 420; }
  .footer__brand p { color: var(--on-dark-soft); margin: 0.9rem 0 1.4rem; max-width: 32ch; }
  .footer__col h2 { font-family: var(--font-mono); font-size: 0.74rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent); margin-bottom: 1rem; font-weight: 500; }
  .footer__col ul { list-style: none; padding: 0; display: grid; gap: 0.6rem; }
  .footer__col a { color: var(--on-dark); text-decoration: none; font-size: 0.95rem; }
  .footer__col a:hover { color: var(--accent); }
  .footer .dim { color: var(--on-dark-soft); font-size: 0.95rem; }
  .footer__base { display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: space-between; padding-block: 1.5rem 2rem; font-size: 0.85rem; color: var(--on-dark-soft); }
  .footer__pledge { color: var(--accent); }
  @media (max-width: 820px) { .footer__grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 520px) { .footer__grid { grid-template-columns: 1fr; } }
</style>
